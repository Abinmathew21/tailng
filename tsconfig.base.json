{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@tailng-ui/cdk": ["libs/tailng-ui/cdk/src/index.ts"],
      "@tailng-ui/cdk/a11y": ["libs/tailng-ui/cdk/src/a11y/index.ts"],
      "@tailng-ui/cdk/collections": ["libs/tailng-ui/cdk/src/collections/index.ts"],
      "@tailng-ui/cdk/core": ["libs/tailng-ui/cdk/src/core/index.ts"],
      "@tailng-ui/cdk/overlay": ["libs/tailng-ui/cdk/src/overlay/index.ts"],
      "@tailng-ui/components": ["libs/tailng-ui/components/src/index.ts"],
      "@tailng-ui/icons": ["libs/tailng-ui/icons/src/index.ts"],
      "@tailng-ui/primitives": ["libs/tailng-ui/primitives/src/index.ts"],
      "@tailng-ui/registry": ["libs/tailng-ui/registry/src/index.ts"],
      "@tailng-ui/theme": ["libs/tailng-ui/theme/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}

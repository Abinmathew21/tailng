{
  "name": "@org/source",
  "version": "0.73.0",
  "license": "MIT",
  "engines": {
    "node": ">=20.20.0",
    "pnpm": ">=10.30.0"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "nx": "nx",
    "build": "NX_DAEMON=false NX_ISOLATE_PLUGINS=false nx run-many -t build",
    "build:cli": "NX_DAEMON=false NX_ISOLATE_PLUGINS=false nx run tailng-cli:build",
    "build:docs": "NX_DAEMON=false NX_ISOLATE_PLUGINS=false nx build docs",
    "build:tailwind": "NX_DAEMON=false NX_ISOLATE_PLUGINS=false nx build playground-tailwind",
    "build:theme": "NX_DAEMON=false NX_ISOLATE_PLUGINS=false nx build theme",
    "build:vanilla": "NX_DAEMON=false NX_ISOLATE_PLUGINS=false nx build playground-plain-css",
    "format:nx": "NX_DAEMON=false NX_ISOLATE_PLUGINS=false nx format:check",
    "format:prettier": "prettier . --check",
    "format:write": "prettier . --write",
    "generate:icons": "node libs/tailng-ui/icons/tools/generate-icon-loaders.mjs",
    "lint": "NX_DAEMON=false NX_ISOLATE_PLUGINS=false nx run-many -t lint",
    "lint:affected": "NX_DAEMON=false NX_ISOLATE_PLUGINS=false nx affected -t lint",
    "prerender:docs": "node tools/prerender/prerender-docs.mjs",
    "prerender:tailwind": "node tools/prerender/prerender-tailwind.mjs",
    "prerender:vanilla": "node tools/prerender/prerender-vanilla.mjs",
    "run:tailng": "NX_DAEMON=false NX_ISOLATE_PLUGINS=false nx run tailng-cli:build --skipNxCache && node dist/libs/tailng/cli/src/index.js",
    "seo:docs": "pnpm run build:docs && pnpm run prerender:docs",
    "seo:tailwind": "pnpm run build:tailwind && pnpm run prerender:tailwind",
    "seo:vanilla": "pnpm run build:vanilla && pnpm run prerender:vanilla",
    "start:docs": "NX_DAEMON=false NX_ISOLATE_PLUGINS=false nx serve docs",
    "start:tailwind": "NX_DAEMON=false NX_ISOLATE_PLUGINS=false nx serve playground-tailwind --port 4202",
    "start:vanilla": "NX_DAEMON=false NX_ISOLATE_PLUGINS=false nx serve playground-plain-css --port 4201",
    "test:all": "vitest run",
    "test:charts": "vitest run libs/tailng-ui/charts",
    "test:cdk": "vitest run libs/tailng-ui/cdk",
    "test:cli": "vitest run libs/tailng/cli",
    "test:components": "vitest run libs/tailng-ui/components",
    "test:docs": "vitest run --config apps/tailng-ui/docs/vitest.config.ts",
    "test:icons": "vitest run libs/tailng-ui/icons",
    "test:packages": "pnpm run test:cdk && pnpm run test:primitives && pnpm run test:components && pnpm run test:theme && pnpm run test:icons && pnpm run test:charts && pnpm run test:registry",
    "test:primitives": "vitest run libs/tailng-ui/primitives",
    "test:registry": "vitest run libs/tailng-ui/registry",
    "test:theme": "vitest run libs/tailng-ui/theme",
    "typecheck:cli": "tsc -p libs/tailng/cli/tsconfig.lib.json --noEmit",
    "typecheck:docs": "tsc -p apps/tailng-ui/docs/tsconfig.app.json --noEmit",
    "typecheck:registry": "tsc -p libs/tailng-ui/registry/tsconfig.lib.json --noEmit",
    "verify:ownable-contracts": "pnpm run test:registry && pnpm run test:cli && pnpm run test:docs && pnpm run typecheck:registry && pnpm run typecheck:cli && pnpm run typecheck:docs"
  },
  "private": true,
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.2.3",
    "@analogjs/vitest-angular": "^2.2.3",
    "@angular-devkit/core": "21.1.1",
    "@angular-devkit/schematics": "21.1.1",
    "@angular-eslint/template-parser": "^21.2.0",
    "@angular/build": "21.1.1",
    "@angular/cli": "21.1.1",
    "@angular/common": "21.1.1",
    "@angular/compiler": "21.1.1",
    "@angular/compiler-cli": "21.1.1",
    "@angular/core": "21.1.1",
    "@angular/forms": "21.1.1",
    "@angular/platform-browser": "21.1.1",
    "@angular/platform-browser-dynamic": "^21.1.5",
    "@angular/router": "21.1.1",
    "@eslint/js": "^9.8.0",
    "@ng-icons/core": "^32.4.0",
    "@ng-icons/lucide": "^33.1.0",
    "@nx/angular": "22.5.0",
    "@nx/eslint": "22.5.0",
    "@nx/eslint-plugin": "22.5.0",
    "@nx/js": "22.5.0",
    "@nx/vite": "22.5.0",
    "@nx/vitest": "22.5.0",
    "@nx/web": "22.5.0",
    "@schematics/angular": "21.1.1",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@tailng-ui/theme": "workspace:*",
    "@types/node": "20.19.9",
    "@typescript-eslint/utils": "^8.40.0",
    "@vitest/coverage-v8": "4.0.9",
    "angular-eslint": "^21.0.1",
    "autoprefixer": "^10.4.0",
    "echarts": "^5.6.0",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "flag-icons": "^7.5.0",
    "jsdom": "^28.1.0",
    "jsonc-eslint-parser": "^2.1.0",
    "nx": "22.5.0",
    "postcss": "^8.4.5",
    "prettier": "~3.6.2",
    "puppeteer": "^24.1.0",
    "rxjs": "~7.8.2",
    "serve-handler": "^6.1.6",
    "shiki": "^4.0.2",
    "tailwindcss": "^3.0.2",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "verdaccio": "^6.0.5",
    "vite": "^7.0.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "4.0.9",
    "zone.js": "0.16.0"
  },
  "nx": {
    "includedScripts": []
  },
  "dependencies": {
    "fuse.js": "^7.3.0"
  },
  "packageManager": "pnpm@10.30.0"
}

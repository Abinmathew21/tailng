{
  "name": "registry",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/tailng-ui/registry/src",
  "projectType": "library",
  "release": {
    "version": {
      "manifestRootsToUpdate": [
        "dist/{projectRoot}"
      ],
      "currentVersionResolver": "git-tag",
      "fallbackCurrentVersionResolver": "disk"
    }
  },
  "tags": [
    "scope:tailng",
    "type:registry"
  ],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/libs/tailng-ui/registry",
        "main": "libs/tailng-ui/registry/src/index.ts",
        "tsConfig": "libs/tailng-ui/registry/tsconfig.lib.json",
        "assets": [
          "libs/tailng-ui/registry/*.md"
        ]
      }
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "dist/{projectRoot}"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "vite:test": {
      "executor": "@nx/vitest:test",
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}"
      ],
      "options": {
        "configFile": "libs/tailng-ui/registry/vitest.config.ts",
        "reportsDirectory": "coverage/libs/tailng-ui/registry",
        "watch": false
      }
    }
  }
}

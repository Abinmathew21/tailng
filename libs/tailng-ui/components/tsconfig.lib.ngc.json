{
  "extends": "./tsconfig.lib.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "../../../dist/libs/tailng-ui/components/src",
    "paths": {
      "@tailng-ui/components": ["libs/tailng-ui/components/src/index.ts"],
      "@tailng-ui/components/*": ["libs/tailng-ui/components/src/*"],
      "@tailng-ui/primitives": ["dist/libs/tailng-ui/primitives/src/index.d.ts"],
      "@tailng-ui/primitives/*": ["dist/libs/tailng-ui/primitives/src/*"],
      "@tailng-ui/cdk": ["dist/libs/tailng-ui/cdk/src/index.d.ts"],
      "@tailng-ui/cdk/*": ["dist/libs/tailng-ui/cdk/src/*"]
    }
  },
  "angularCompilerOptions": {
    "compilationMode": "partial"
  }
}

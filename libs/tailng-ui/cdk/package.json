{
  "name": "@tailng-ui/cdk",
  "version": "0.9.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/tailng/tailng-ui"
  },
  "type": "commonjs",
  "main": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"

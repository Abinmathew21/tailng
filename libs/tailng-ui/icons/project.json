{
  "name": "icons",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/tailng-ui/icons/src",
  "projectType": "library",
  "release": {
    "version": {
      "manifestRootsToUpdate": ["dist/{projectRoot}"],
      "currentVersionResolver": "git-tag",
      "fallbackCurrentVersionResolver": "disk"
    }
  },
  "tags": ["scope:tailng", "type:icons"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["generate"],
      "outputs": ["{workspaceRoot}/dist/libs/tailng-ui/icons"],
      "options": {
        "command": "node tools/build/build-icons.mjs"
      }
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "dist/{projectRoot}"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "dependsOn": ["generate"]
    },
    "vite:test": {
      "executor": "@nx/vitest:test",
      "dependsOn": ["generate"],
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "configFile": "libs/tailng-ui/icons/vitest.config.ts",
        "reportsDirectory": "coverage/libs/tailng-ui/icons",
        "watch": false
      }
    },
    "generate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node libs/tailng-ui/icons/tools/generate-icon-loaders.mjs"
      }
    }
  }
}

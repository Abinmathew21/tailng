{
  "name": "primitives",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/tailng-ui/primitives/src",
  "prefix": "tng",
  "projectType": "library",
  "release": {
    "version": {
      "manifestRootsToUpdate": [
        "dist/{projectRoot}"
      ],
      "currentVersionResolver": "git-tag",
      "fallbackCurrentVersionResolver": "disk"
    }
  },
  "tags": [
    "scope:tailng",
    "type:primitives"
  ],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "{workspaceRoot}/dist/libs/tailng-ui/primitives"
      ],
      "options": {
        "command": "node tools/build/build-primitives.mjs"
      }
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "dist/{projectRoot}"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "vite:test": {
      "executor": "@nx/vitest:test",
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}"
      ],
      "options": {
        "configFile": "libs/tailng-ui/primitives/vitest.config.ts",
        "reportsDirectory": "coverage/libs/tailng-ui/primitives",
        "watch": false
      }
    }
  }
}

{
  "name": "@tailng-ui/theme",
  "version": "0.55.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tailng/tailng-ui"
  },
  "type": "commonjs",
  "main": "./src/index.js",
  "style": "./index.css",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "style": "./index.css",
      "default": "./src/index.js"
    },
    "./index.css": "./index.css",
    "./component-contracts/index.css": "./component-contracts/index.css",
    "./component-contracts/*": "./component-contracts/*",
    "./component-contracts/*/*": "./component-contracts/*/*"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "peerDependencies": {
    "@angular/core": "^21.1.0"
  }
}
